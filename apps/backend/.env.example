# Copy to .env and fill in values
PORT=5000
DATABASE_URL="postgresql://user:password@localhost:5432/intern_link"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN="7d"
NODE_ENV="development"

# --- AI chat (use at least one) ---
# Recommended for students: Google Gemini (free tier) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional alias:
# GOOGLE_GENERATIVE_AI_API_KEY=

# Chat model (default: gemini-2.5-flash). Override if your region uses another id.
# GEMINI_CHAT_MODEL=gemini-2.5-flash

# Force chat to use OpenAI when both keys are set:
# AI_CHAT_PROVIDER=openai

# OpenAI — weekly plan / feedback JSON endpoints, or chat if no Gemini key
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Weekly plan + feedback (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# OpenAI chat only (default: gpt-4o)
# OPENAI_CHAT_MODEL=gpt-4o

# Dev-only: stub weekly plan / feedback when OPENAI_API_KEY unset (chat uses Gemini or OpenAI)
# AI_USE_MOCK=true

# --- Cloudinary Configuration ---
CLOUDINARY_CLOUD_NAME=dhhlz8ruy
CLOUDINARY_API_KEY=your_api_key
