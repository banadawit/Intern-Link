
generator client {
  provider = "prisma-client-js"

}
// supabase password amanuell2123A@
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum Role {
  ADMIN
  COORDINATOR
  HOD
  SUPERVISOR
  STUDENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum InternshipStatus {
  PENDING
  PLACED
  COMPLETED
}

enum AssignmentStatus {
  ACTIVE
  COMPLETED
  TERMINATED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

// --- MODELS (Tables 2 - 17) ---

model User {
  id                Int            @id @default(autoincrement())
  reset_password_token   String?
  reset_password_expires DateTime?
  full_name         String
  email             String         @unique
  password_hash     String
  role              Role
  verification_status ApprovalStatus @default(PENDING)

  // ✅ NEW: Email Verification Fields
  verification_token       String?        @unique
  verification_token_expiry DateTime?
  verification_document    String?

  /// COORDINATOR/SUPERVISOR/HOD: Pending until admin (coord./sup.) or coordinator (HOD) approves. STUDENT/ADMIN default APPROVED.
  institution_access_approval ApprovalStatus @default(APPROVED)

  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt

  

  // Specific Role Relations
  studentProfile    Student?
  coordinatorProfile Coordinator?
  hodProfile        HodProfile?
  supervisorProfile Supervisor?
  
  // Announcements & Notifications
  announcements     Announcement[]
  notifications     Notification[]
  
  // Common Feed
  commonPosts       CommonPost[]
  postComments      PostComment[]
  postLikes         PostLike[]
  postViews         PostView[]
  postReports       PostReport[]

  aiChatMessages    AiChatMessage[]
  activityLogs      ActivityLog[]
}

/// Daily activity counts for contribution heatmap (login, submissions, etc.).
model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  count     Int      @default(0)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("activity_logs")
}

/// Persisted AI assistant chat (one thread per user; chronological messages)
model AiChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  speaker   String   // "user" | "assistant"
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model University {
  id                Int            @id @default(autoincrement())
  name              String
  official_email    String         @unique
  address           String?
  verification_doc  String?        // URL/Path to PDF
  approval_status   ApprovalStatus @default(PENDING)
  created_at        DateTime       @default(now())

  rejection_reason String?
  coordinators      Coordinator[]
  hods              HodProfile[]
  students          Student[]
  proposalsSent     InternshipProposal[]
  reportsReceived   Report[] @relation("ReportToUniversity")
}

model Company {
  id                Int            @id @default(autoincrement())
  name              String
  official_email    String         @unique
  address           String?
  stamp_image_url   String?
  verification_doc  String?
  rejection_reason String?
  approval_status   ApprovalStatus @default(PENDING)
  created_at        DateTime       @default(now())

  supervisors       Supervisor[]
  assignments       InternshipAssignment[]
  proposalsReceived InternshipProposal[]
  teams             Team[]
  projects          Project[]
}

model Coordinator {
  id            Int         @id @default(autoincrement())
  user          User        @relation(fields: [userId], references: [id])
  userId        Int         @unique
  university    University? @relation(fields: [universityId], references: [id])
  universityId  Int?
  /// Stored during registration; used to create the University record upon admin approval
  pending_university_name String?
  phone_number  String?
}

model HodProfile {
  id           Int        @id @default(autoincrement())
  user         User       @relation(fields: [userId], references: [id])
  userId       Int        @unique
  university   University @relation(fields: [universityId], references: [id])
  universityId Int
  department   String
  employeeId   String?
}

model Supervisor {
  id            Int       @id @default(autoincrement())
  user          User      @relation(fields: [userId], references: [id])
  userId        Int       @unique
  company       Company   @relation(fields: [companyId], references: [id])
  companyId     Int
  phone_number  String?
  
  evaluations   FinalEvaluation[]
  weeklyReports WeeklyReport[]
}

model Student {
  id                Int              @id @default(autoincrement())
  user              User             @relation(fields: [userId], references: [id])
  userId            Int              @unique
  university        University       @relation(fields: [universityId], references: [id])
  universityId      Int
  registration_type String           // e.g. "Official" or "Personal"
  internship_status InternshipStatus @default(PENDING)
  created_at        DateTime         @default(now())

  studentId         String?          
  department        String?
  /// HOD must approve self-registered students before full access (coordinator-registered students are APPROVED).
  hod_approval_status ApprovalStatus @default(APPROVED)

  assignments       InternshipAssignment[]
  weeklyPlans       WeeklyPlan[]
  proposals         InternshipProposal[]
  finalEvaluation   FinalEvaluation?
  finalReport       Report?
  weeklyReports     WeeklyReport[]
  studentTeams      StudentTeam[]
  studentProjects   StudentProject[]
}

model InternshipProposal {
  id            Int            @id @default(autoincrement())
  university    University     @relation(fields: [universityId], references: [id])
  universityId  Int
  company       Company        @relation(fields: [companyId], references: [id])
  companyId     Int
  student       Student        @relation(fields: [studentId], references: [id])
  studentId     Int
  status        ApprovalStatus @default(PENDING)
  proposal_type String         // "University_Initiated" or "Open_Letter"
  submitted_at  DateTime       @default(now())
  expected_duration_weeks Int?
  expected_outcomes       String?    @db.Text
  responded_at            DateTime?

  @@index([studentId, companyId, status])
}

model InternshipAssignment {
  id            Int              @id @default(autoincrement())
  student       Student          @relation(fields: [studentId], references: [id])
  studentId     Int
  company       Company          @relation(fields: [companyId], references: [id])
  companyId     Int
  start_date    DateTime
  end_date      DateTime?
  status        AssignmentStatus @default(ACTIVE)
   project_name String? 
}

model WeeklyPlan {
  id               Int            @id @default(autoincrement())
  student          Student        @relation(fields: [studentId], references: [id])
  studentId        Int
  week_number      Int
  plan_description String         @db.Text
  status           ApprovalStatus @default(PENDING)
  submitted_at     DateTime       @default(now())
  feedback         String?        @db.Text
  reviewed_at      DateTime?
  version          Int            @default(1)

  presentation     WeeklyPresentation?
  weeklyReports    WeeklyReport[]
  daySubmissions   WeeklyPlanDaySubmission[]
}

/// One row per calendar day the student marked as submitted for that approved weekly plan (daily check-in).
model WeeklyPlanDaySubmission {
  id             Int        @id @default(autoincrement())
  weeklyPlan     WeeklyPlan @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  weeklyPlanId   Int
  workDate       DateTime   @db.Date
  notes          String?    @db.Text
  submittedAt    DateTime   @default(now())

  @@unique([weeklyPlanId, workDate])
  @@index([weeklyPlanId])
}

model WeeklyPresentation {
  id             Int        @id @default(autoincrement())
  weeklyPlan     WeeklyPlan @relation(fields: [weeklyPlanId], references: [id])
  weeklyPlanId   Int        @unique
  file_url       String     // Path to PPT/PDF
  uploaded_at    DateTime   @default(now())
}

model WeeklyReport {
  id               Int              @id @default(autoincrement())
  studentId        Int
  student          Student          @relation(fields: [studentId], references: [id])
  weeklyPlanId     Int?             @unique
  weeklyPlan       WeeklyPlan?      @relation(fields: [weeklyPlanId], references: [id])
  supervisor       Supervisor       @relation(fields: [supervisorId], references: [id])
  supervisorId     Int
  attendanceStatus AttendanceStatus @default(PRESENT)
  execution_status String?          @db.Text
  remarks          String?          @db.Text
  submitted_at     DateTime         @default(now())
}

model FinalEvaluation {
  id              Int        @id @default(autoincrement())
  student         Student    @relation(fields: [studentId], references: [id])
  studentId       Int        @unique
  supervisor      Supervisor @relation(fields: [supervisorId], references: [id])
  supervisorId    Int
  technical_score Decimal    @db.Decimal(5, 2)
  soft_skill_score Decimal   @db.Decimal(5, 2)
  comments        String?    @db.Text
  evaluated_at    DateTime   @default(now())
}

model Report {
  id                   Int         @id @default(autoincrement())
  student              Student     @relation(fields: [studentId], references: [id])
  studentId            Int         @unique
  pdf_url              String
  stamped              Boolean     @default(false)
  generated_at         DateTime    @default(now())
  sent_at              DateTime?
  locked               Boolean     @default(false)
  sentToUniversityId   Int?
  sentToUniversity     University? @relation("ReportToUniversity", fields: [sentToUniversityId], references: [id])
}

model Team {
  id         Int           @id @default(autoincrement())
  name       String
  companyId  Int
  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  members    StudentTeam[]
  created_at DateTime      @default(now())
}

model StudentTeam {
  studentId Int
  teamId    Int
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([studentId, teamId])
}

model Project {
  id         Int               @id @default(autoincrement())
  name       String
  companyId  Int
  company    Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  students   StudentProject[]
  created_at DateTime          @default(now())
}

model StudentProject {
  studentId Int
  projectId Int
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([studentId, projectId])
}

enum PostType {
  ANNOUNCEMENT
  OPPORTUNITY
  EXPERIENCE
  GENERAL_UPDATE
}

enum PostVisibility {
  PUBLIC          // Visible to all authenticated users
  UNIVERSITY      // Visible to specific university members
  COMPANY         // Visible to specific company members
  ROLE_SPECIFIC   // Visible to specific roles
}

model Announcement {
  id         Int      @id @default(autoincrement())
  author     User     @relation(fields: [authorId], references: [id])
  authorId   Int
  title      String
  content    String   @db.Text
  created_at DateTime @default(now())
}

model CommonPost {
  id              Int            @id @default(autoincrement())
  author          User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId        Int
  postType        PostType       @default(GENERAL_UPDATE)
  visibility      PostVisibility @default(PUBLIC)
  title           String
  content         String         @db.Text
  
  // Optional attachments
  imageUrls       String[]       @default([])
  documentUrls    String[]       @default([])
  
  // Visibility filters
  targetUniversityId Int?
  targetCompanyId    Int?
  targetRoles        Role[]       @default([])
  
  // Engagement metrics
  viewCount       Int            @default(0)
  likeCount       Int            @default(0)
  commentCount    Int            @default(0)
  
  // Moderation
  isModerated     Boolean        @default(false)
  isPinned        Boolean        @default(false)
  isArchived      Boolean        @default(false)
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  // Relations
  comments        PostComment[]
  likes           PostLike[]
  views           PostView[]
  reports         PostReport[]
  
  @@index([authorId, createdAt])
  @@index([postType, createdAt])
  @@index([visibility, createdAt])
  @@index([isPinned, isArchived, createdAt])
}

model PostComment {
  id          Int        @id @default(autoincrement())
  post        CommonPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId      Int
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId    Int
  content     String     @db.Text
  
  // Nested comments support
  parentId    Int?
  parent      PostComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     PostComment[] @relation("CommentReplies")
  
  isEdited    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@index([postId, createdAt])
  @@index([authorId])
}

model PostLike {
  id        Int        @id @default(autoincrement())
  post      CommonPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    Int
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  createdAt DateTime   @default(now())
  
  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model PostView {
  id        Int        @id @default(autoincrement())
  post      CommonPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    Int
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  viewedAt  DateTime   @default(now())
  
  @@unique([postId, userId])
  @@index([postId])
}

model PostReport {
  id          Int        @id @default(autoincrement())
  post        CommonPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId      Int
  reporter    User       @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reporterId  Int
  reason      String
  description String?    @db.Text
  status      String     @default("PENDING") // PENDING, REVIEWED, RESOLVED
  createdAt   DateTime   @default(now())
  reviewedAt  DateTime?
  
  @@index([postId])
  @@index([reporterId])
  @@index([status])
}

model Notification {
  id           Int      @id @default(autoincrement())
  recipient    User     @relation(fields: [recipientId], references: [id])
  recipientId  Int
  message      String   @db.Text
  is_read      Boolean  @default(false)
  created_at   DateTime @default(now())
}
model AuditLog {
  id          Int      @id @default(autoincrement())
  adminId     Int
  action      String   // e.g., "APPROVED_UNIVERSITY"
  targetId    Int      // ID of the university or company
  details     String?  // e.g., "Approved Haramaya University"
  timestamp   DateTime @default(now())
}