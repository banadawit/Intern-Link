# --- INTERNLINK MASTER IGNORE ---

# Dependencies
**/node_modules
**/dist
**/.pnp
**/.pnp.*
**/.yarn/*
# Allow specific yarn files
!/**/.yarn/patches
!/**/.yarn/plugins
!/**/.yarn/releases
!/**/.yarn/versions

# Next.js & Frontend
**/.next/
**/out/
**/build
**/next-env.d.ts

# NestJS & Backend
**/dist/
**/coverage
*.tsbuildinfo

# Environment Variables (Safety First)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/.env.*
# DO NOT ignore the template
!**/.env.example

# Debugging & Logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*

# IDEs & System
.vscode/
.idea/
.DS_Store
Thumbs.db
*.pem

# Infrastructure (Docker data)
infrastructure/db-data/

# Uploaded files
**/uploads/